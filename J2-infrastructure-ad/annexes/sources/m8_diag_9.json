{
  "type": "sequence",
  "width": 880,
  "height": 520,
  "title": "Authentification Kerberos",
  "participants": [
    {"id": "client", "label": "Client\n(Utilisateur)"},
    {"id": "kdc", "label": "KDC (DC)\n(KRBTGT)"},
    {"id": "service", "label": "Service\n(Serveur)"}
  ],
  "messages": [
    {"from": "client", "to": "kdc", "label": "1. AS-REQ (demande TGT)"},
    {"from": "kdc", "to": "client", "label": "2. AS-REP (TGT + session key)", "type": "response"},
    {"from": "client", "to": "kdc", "label": "3. TGS-REQ (TGT + SPN)"},
    {"from": "kdc", "to": "client", "label": "4. TGS-REP (TGS service)", "type": "response"},
    {"from": "client", "to": "service", "label": "5. AP-REQ (TGS vers service)"},
    {"from": "service", "to": "client", "label": "6. AP-REP (authentification)", "type": "response"}
  ]
}
